# Set default behavior
* text=auto eol=lf

# Force LF for specific file types
*.js text eol=lf
*.ts text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.py text eol=lf
*.sh text eol=lf

# Do not process binary files
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.pdf binary